---
layout: null
---
{
  "nodes": [
    {% for post in site.posts %}
    {
      "id": "{{ post.url | slugify }}",
      "title": {{ post.title | jsonify }},
      "url": "{{ post.url | relative_url }}",
      "tags": {{ post.tags | jsonify }},
      "categories": {{ post.categories | jsonify }},
      "date": "{{ post.date | date: '%Y-%m-%d' }}"
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
  "links": [
    {% assign link_pairs = "" | split: "" %}
    {% for post in site.posts %}
      {% for tag in post.tags %}
        {% for other in site.posts %}
          {% if other.url != post.url and other.tags contains tag %}
            {% assign pair_a = post.url | slugify %}
            {% assign pair_b = other.url | slugify %}
            {% if pair_a < pair_b %}
              {% assign pair_key = pair_a | append: "|||" | append: pair_b %}
              {% unless link_pairs contains pair_key %}
                {% assign link_pairs = link_pairs | push: pair_key %}
              {% endunless %}
            {% endif %}
          {% endif %}
        {% endfor %}
      {% endfor %}
    {% endfor %}
    {% for pair in link_pairs %}
      {% assign parts = pair | split: "|||" %}
      { "source": "{{ parts[0] }}", "target": "{{ parts[1] }}" }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
